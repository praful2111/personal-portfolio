{
  "key": "group_portfolio_options",
  "title": "Portfolio Options Page Fields",
  "fields": [
    {
      "key": "field_hero_group",
      "label": "Hero Section",
      "name": "hero_section",
      "type": "group",
      "sub_fields": [
        { "key": "field_hero_greeting", "label": "Greeting Text", "name": "hero_greeting", "type": "text", "default_value": "👋 Hello, I'm Praful" },
        { "key": "field_hero_name", "label": "Full Name", "name": "hero_name", "type": "text", "default_value": "Praful Patel" },
        { "key": "field_hero_title", "label": "Title (non-italic)", "name": "hero_title", "type": "text", "default_value": "Full-Stack" },
        { "key": "field_hero_title_italic", "label": "Title (italic)", "name": "hero_title_italic", "type": "text", "default_value": "Web Developer" },
        { "key": "field_hero_description", "label": "Hero Description", "name": "hero_description", "type": "textarea", "rows": 3 },
        { "key": "field_hero_years", "label": "Years of Experience", "name": "hero_years_experience", "type": "text", "default_value": "8+" },
        { "key": "field_hero_cta_primary", "label": "Primary CTA Label", "name": "hero_cta_primary", "type": "text", "default_value": "Explore My Skills" },
        { "key": "field_hero_cta_secondary", "label": "Secondary CTA Label", "name": "hero_cta_secondary", "type": "text", "default_value": "Get in Touch" }
      ]
    },
    {
      "key": "field_about_group",
      "label": "About Section",
      "name": "about_section",
      "type": "group",
      "sub_fields": [
        { "key": "field_about_bio1", "label": "Bio Paragraph 1", "name": "about_bio_para1", "type": "textarea", "rows": 4 },
        { "key": "field_about_bio2", "label": "Bio Paragraph 2", "name": "about_bio_para2", "type": "textarea", "rows": 4 },
        { "key": "field_about_tags", "label": "Skill Tags (comma-separated)", "name": "about_tags", "type": "textarea", "instructions": "e.g. WordPress, PHP, React.js, WooCommerce" },
        {
          "key": "field_about_quick_facts",
          "label": "Quick Facts",
          "name": "about_quick_facts",
          "type": "repeater",
          "layout": "table",
          "sub_fields": [
            { "key": "field_fact_icon", "label": "Icon (emoji)", "name": "icon", "type": "text" },
            { "key": "field_fact_label", "label": "Label", "name": "label", "type": "text" }
          ],
          "default_value": [
            { "icon": "📍", "label": "Based in India" },
            { "icon": "💼", "label": "8+ Years Experience" },
            { "icon": "🌐", "label": "WordPress Community Organiser" },
            { "icon": "🎤", "label": "WordCamp Speaker & Organiser" },
            { "icon": "🤝", "label": "Available for Freelance" },
            { "icon": "🌍", "label": "Remote-Friendly & Global Clients" },
            { "icon": "⚡", "label": "Open Source Contributor" }
          ]
        },
        {
          "key": "field_about_highlights",
          "label": "Highlight Cards",
          "name": "about_highlights",
          "type": "repeater",
          "layout": "block",
          "sub_fields": [
            { "key": "field_hl_title", "label": "Title", "name": "title", "type": "text" },
            { "key": "field_hl_description", "label": "Description", "name": "description", "type": "textarea", "rows": 3 },
            { "key": "field_hl_icon", "label": "Icon (emoji)", "name": "icon", "type": "text" },
            { "key": "field_hl_color", "label": "Accent Color (oklch string)", "name": "accentColor", "type": "text" }
          ]
        }
      ]
    },
    {
      "key": "field_achievements_group",
      "label": "Achievements Section",
      "name": "achievements_section",
      "type": "group",
      "sub_fields": [
        { "key": "field_ach_description", "label": "Description", "name": "achievements_description", "type": "textarea", "rows": 3 },
        {
          "key": "field_ach_stats",
          "label": "Stats",
          "name": "achievements_stats",
          "type": "repeater",
          "layout": "table",
          "sub_fields": [
            { "key": "field_stat_value", "label": "Value", "name": "value", "type": "text" },
            { "key": "field_stat_label", "label": "Label", "name": "label", "type": "text" }
          ]
        },
        {
          "key": "field_ach_timeline",
          "label": "Timeline Events",
          "name": "achievements_timeline",
          "type": "repeater",
          "layout": "block",
          "sub_fields": [
            { "key": "field_tl_year", "label": "Year", "name": "year", "type": "text" },
            { "key": "field_tl_title", "label": "Title", "name": "title", "type": "text" },
            { "key": "field_tl_description", "label": "Description", "name": "description", "type": "textarea", "rows": 2 }
          ]
        }
      ]
    },
    {
      "key": "field_contact_group",
      "label": "Contact Section",
      "name": "contact_section",
      "type": "group",
      "sub_fields": [
        { "key": "field_contact_heading", "label": "Section Heading", "name": "contact_heading", "type": "text", "default_value": "Let's Work Together" },
        { "key": "field_contact_email", "label": "Email", "name": "contact_email", "type": "email" },
        { "key": "field_contact_phone", "label": "Phone", "name": "contact_phone", "type": "text" }
      ]
    }
  ],
  "location": [
    [
      {
        "param": "options_page",
        "operator": "==",
        "value": "portfolio-settings"
      }
    ]
  ]
}
